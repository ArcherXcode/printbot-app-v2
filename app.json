{
  "expo": {
    "name": "PrintBot",
    "slug": "SayHellotoInstantPrinting",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icons/icon-light.png",
    "scheme": "expoprintbotapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/icons/splash-black.png",
      "resizeMode": "contain",
      "backgroundColor": "#E0F3FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "cloud.printbot.app",
      "icon": "./assets/images/icons/printbot.icon"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icons/adaptive-icon.png",
        "backgroundColor": "#E0F3FF"
      },
      "predictiveBackGestureEnabled": true,
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_MEDIA_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "package": "cloud.printbot.app",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}